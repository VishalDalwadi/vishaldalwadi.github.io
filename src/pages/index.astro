---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';

const homepageJsonPath = path.join(process.cwd(), 'src/data/homepage.json');
const sceneSvgPath = path.join(process.cwd(), 'src/data/scenes/homepage.svg');

const hasHomepageScene = fs.existsSync(homepageJsonPath) && fs.existsSync(sceneSvgPath);

const homepage = hasHomepageScene
  ? JSON.parse(fs.readFileSync(homepageJsonPath, 'utf-8'))
  : {
      title: 'paperplanes.cloud — a notebook about things that fly, roll, or launch',
      seoDescription: 'A notebook about planes, space, rockets, physics, cars, and trains — things that fly, roll, or launch.',
      links: [],
    };

const sceneSvg = hasHomepageScene ? fs.readFileSync(sceneSvgPath, 'utf-8') : null;
---

<BaseLayout title={homepage.title} description={homepage.seoDescription}>
  <main class="page">
    {sceneSvg ? (
      <div class="scene-wrap">
        <div class="scene" set:html={sceneSvg} />
        {homepage.links.map((link: { href: string; left: number; top: number; width: number; height: number }) => (
          <a
            class="hotspot"
            href={link.href}
            style={`left:${link.left}%; top:${link.top}%; width:${link.width}%; height:${link.height}%;`}
          />
        ))}
      </div>
    ) : (
      <p class="empty-note">
        no homepage scene yet — run <code>npm run new-homepage</code>, draw it in Excalidraw, then save it to
        <code>scenes/homepage.excalidraw</code>.
      </p>
    )}
  </main>
</BaseLayout>

<style>
  .page {
    min-height: 100vh;
    background-color: var(--pp-bg-corkboard);
    background-image: var(--pp-dots-24);
    background-size: 24px 24px;
    display: flex;
    justify-content: center;
    padding: 40px 20px;
  }
  .scene-wrap {
    position: relative;
    width: 100%;
    max-width: 900px;
  }
  .scene :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }
  .hotspot {
    position: absolute;
    display: block;
  }
  .hotspot:hover {
    outline: 2px dashed var(--pp-accent);
    outline-offset: 2px;
  }
  .empty-note {
    font-family: var(--pp-font);
    color: var(--pp-muted-6);
    font-size: 15px;
    max-width: 500px;
    text-align: center;
    margin-top: 80px;
  }
  .empty-note code {
    background: rgba(30, 30, 30, 0.08);
    padding: 2px 6px;
    border-radius: 3px;
  }
</style>
